# Docker Environment Configuration for staging
# Generated on 2025-09-12T22:47:44.335Z

NODE_ENV=staging
PORT=3000
DATABASE_URL=postgres://binaai_user:${DB_PASSWORD}@${DB_HOST}:5432/binaai_staging
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50

# Docker-specific variables
POSTGRES_DB=binaai_staging
POSTGRES_USER=binaai_user
POSTGRES_PASSWORD=binaai_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379
